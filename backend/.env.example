# Server Configuration
PORT=5000
NODE_ENV=development
API_VERSION=v1
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Database Configuration (PostgreSQL connection string)
DATABASE_URL="postgresql://db_user:db_password@localhost:5432/luxury_jewelry?schema=public"

# Redis Configuration (For rate limiting & websocket messaging logs caching)
REDIS_URL="redis://localhost:6379"

# Security Configurations
JWT_ACCESS_SECRET="super_secret_jwt_access_string_replace_in_production"
JWT_REFRESH_SECRET="super_secret_jwt_refresh_string_replace_in_production"
COOKIE_SECRET="cookie_parser_signing_secret_string"
OTP_ENCRYPTION_KEY="32_byte_aes_key_for_encrypting_otps"

# OAuth Configuration
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Email Configuration (SMTP / Resend / Sendgrid)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
EMAIL_FROM="concierge@yourluxurybrand.com"

# Cloudinary Config (Asset Storage)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Payments Config
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="razorpay_secret_..."
RAZORPAY_WEBHOOK_SECRET="rzp_whsec_..."
