datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  passwordHash     String?       // Nullable for OAuth logins
  name             String
  role             String        @default("CUSTOMER") // CUSTOMER, GEMOLOGIST, ORDER_MANAGER, ADMIN
  isEmailVerified  Boolean       @default(false)
  phone            String?       @unique
  isPhoneVerified  Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  profile          Profile?
  otps             Otp[]
  orders           Order[]
  appointments     Appointment[] @relation("CustomerAppointments")
  consultations    Appointment[] @relation("ConsultantAppointments")
  reviews          Review[]
  auditLogs        AuditLog[]
  cart             Cart?
  addresses        Address[]
  wishlist         WishlistItem[]

  @@index([email])
}

model Profile {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl      String?
  kycStatus      String    @default("NONE") // PENDING, APPROVED, REJECTED, NONE
  kycDocumentUrl String?
  billingAddress String?   // Serialized JSON string for SQLite compatibility
  shippingAddress String?  // Serialized JSON string for SQLite compatibility
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String   // Address label, e.g. "Home", "Office"
  type         String   @default("SHIPPING") // SHIPPING, BILLING
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String   // SHA-256 hash of the generated OTP code for security
  type      String   // EMAIL_VERIFICATION, PHONE_VERIFICATION, PASSWORD_RESET, MFA
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())
  
  @@index([userId, expiresAt])
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
}

model Collection {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
}

model Coupon {
  id                 String    @id @default(uuid())
  code               String    @unique
  discountType       String    // PERCENTAGE, FIXED
  discountValue      Decimal
  minOrderAmount     Decimal?
  maxDiscountAmount  Decimal?
  expiresAt          DateTime
  isActive           Boolean   @default(true)
  usageLimit         Int?
  usageCount         Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([code])
}

model Product {
  id             String                 @id @default(uuid())
  name           String
  slug           String                 @unique
  sku            String                 @unique
  description    String
  basePrice      Decimal
  isCustomizable Boolean                @default(false)
  categoryId     String
  category       Category               @relation(fields: [categoryId], references: [id])
  status         String                 @default("DRAFT")  // DRAFT, ACTIVE, ARCHIVED
  rating         Float                  @default(0.0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  
  metalConfigs   ProductMetalConfig[]
  variants       ProductVariant[]
  reviews        Review[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  collections    Collection[]
  wishlistItems  WishlistItem[]

  @@index([slug, sku])
}

model ProductMetalConfig {
  id              String    @id @default(uuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  metalType       String    // YELLOW_GOLD_18K, WHITE_GOLD_18K, ROSE_GOLD_18K, PLATINUM
  priceAdjustment Decimal
  
  @@unique([productId, metalType])
}

model ProductVariant {
  id              String      @id @default(uuid())
  productId       String
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String      @unique
  metalType       String      // YELLOW_GOLD_18K, WHITE_GOLD_18K, ROSE_GOLD_18K, PLATINUM
  ringSize        Decimal?
  price           Decimal
  stock           Int         @default(0)
  imageUrls       String      // JSON stringified array of URLs for SQLite compatibility
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([productId])
}

model Gemstone {
  id                String         @id @default(uuid())
  type              String         @default("DIAMOND") // DIAMOND, SAPPHIRE, EMERALD, etc.
  shape             String         // ROUND, OVAL, CUSHION, PEAR, EMERALD, PRINCESS, MARQUISE, RADIANT, HEART
  carat             Decimal
  color             String         // D, E, F, etc.
  clarity           String         // FL, IF, VVS1, VS2, etc.
  cut               String?        // EXCELLENT, VERY_GOOD
  certificateNumber String?        @unique            // GIA or IGI Certificate ID
  certificateUrl    String?
  price             Decimal
  status            String         @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD
  createdAt         DateTime       @default(now())
  
  orderItems        OrderItem[]
  cartItems         CartItem[]

  @@index([type, shape, carat, price])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id              String         @id @default(uuid())
  cartId          String
  cart            Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Int            @default(1)
  selectedMetal   String?
  selectedSize    Decimal?
  customEngraving String?
  selectedGemstoneId String?
  selectedGemstone   Gemstone?   @relation(fields: [selectedGemstoneId], references: [id])

  @@index([cartId])
  @@index([productId])
}

model WishlistItem {
  id                 String     @id @default(uuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId          String
  product            Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  selectedMetal      String?
  selectedSize       Decimal?
  selectedGemstoneId String?    // Gemstone if a customized item is wishlisted
  createdAt          DateTime   @default(now())

  @@index([userId])
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique // Human readable high-end code (e.g. BYD-2026-X8F9)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          String        @default("PENDING_PAYMENT") // PENDING_PAYMENT, PAID, PROCESSING, MANUFACTURING, etc.
  totalAmount     Decimal
  taxAmount       Decimal
  shippingAmount  Decimal
  shippingAddress String        // Serialized JSON shipping address for SQLite compatibility
  billingAddress  String        // Serialized JSON billing address for SQLite compatibility
  trackingNumber  String?
  carrier         String?       // "FedEx Priority Insured", "Brink's Securmark"
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  items           OrderItem[]
  payment         Payment?

  @@index([userId, status])
}

model OrderItem {
  id                 String     @id @default(uuid())
  orderId            String
  order              Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId          String
  product            Product    @relation(fields: [productId], references: [id])
  quantity           Int
  price              Decimal
  selectedMetal      String?
  selectedSize       Decimal?
  customEngraving    String?
  selectedGemstoneId String?
  selectedGemstone   Gemstone?  @relation(fields: [selectedGemstoneId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id              String         @id @default(uuid())
  orderId         String         @unique
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gateway         String         // STRIPE, RAZORPAY, BANK_TRANSFER
  transactionId   String         @unique
  amount          Decimal
  currency        String         @default("USD")
  status          String         @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  gatewayResponse String?        // Serialized JSON string for SQLite compatibility
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Appointment {
  id             String            @id @default(uuid())
  customerId     String
  customer       User              @relation("CustomerAppointments", fields: [customerId], references: [id])
  consultantId   String?           // Assigned Gemologist or Luxury Consultant
  consultant     User?             @relation("ConsultantAppointments", fields: [consultantId], references: [id])
  scheduledAt    DateTime
  type           String            @default("VIRTUAL") // VIRTUAL, IN_STORE
  status         String            @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  notes          String?
  meetingLink    String?           // Zoom, Google Meet link for virtual gemologist consult
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([customerId])
  @@index([consultantId])
}

model Review {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  productId          String
  product            Product  @relation(fields: [productId], references: [id])
  rating             Int      @default(5)
  comment            String?
  isVerifiedPurchase Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@unique([userId, productId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g. "USER_LOGIN", "ADMIN_PRICE_UPDATE", "STRIPE_WEBHOOK_RECEIVED"
  ipAddress String?
  userAgent String?
  details   String?  // Serialized JSON details for SQLite compatibility
  createdAt DateTime @default(now())
}
