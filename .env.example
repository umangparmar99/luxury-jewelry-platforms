# Server Configuration
PORT=5000
NODE_ENV=development
API_VERSION=v1
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Database Configuration (MySQL connection string)
# Replace root, password, localhost, 3306, and database_name with your MySQL values.
DATABASE_URL="mysql://root:your_mysql_password@localhost:3306/luxury_jewelry"

# Security Configurations
JWT_ACCESS_SECRET="your_jwt_access_signature_secret_key"
JWT_REFRESH_SECRET="your_jwt_refresh_signature_secret_key"
COOKIE_SECRET="your_cookie_parser_signing_secret"
OTP_ENCRYPTION_KEY="your_32_byte_aes_encryption_key_for_otps"

# OAuth Configuration (Google Sign-In)
GOOGLE_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

# Email Configuration (SMTP Client Details)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_server_username"
SMTP_PASS="smtp_server_password"
EMAIL_FROM="concierge@beyondcarat.com"

# Cloudinary Configuration (Image Upload Storage API)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Payment Gateway Keys
STRIPE_SECRET_KEY="sk_test_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_stripe_webhook_signing_secret"
RAZORPAY_KEY_ID="rzp_test_razorpay_key_id"
RAZORPAY_KEY_SECRET="razorpay_gateway_secret_key"
RAZORPAY_WEBHOOK_SECRET="rzp_whsec_razorpay_webhook_secret"

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:5000/api/v1"
